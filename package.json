{
  "name": "stocks-assist",
  "version": "1.0.0",
  "description": "股票助手 - 自选标的管理系统",
  "scripts": {
    "dev:backend": "cd backend && uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:all": "npm run dev:backend & npm run dev:frontend",
    "build:frontend": "cd frontend && npm run build",
    "install:frontend": "cd frontend && npm install",
    "install:all": "npm run install:backend && npm run install:frontend",
    "init:db": "cd backend && python -m migrations.init_db",
    "test:backend": "cd backend && python -m pytest tests/ -v",
    "install:backend": "cd backend && pip install -r requirements.txt"
  },
  "keywords": ["stocks", "watchlist", "fastapi", "react"],
  "license": "MIT"
}

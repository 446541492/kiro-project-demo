{
  "buildCommand": "cd frontend && npm ci && npm run build",
  "outputDirectory": "frontend/dist",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/((?!api/).*)", "destination": "/frontend/dist/index.html" }
  ],
  "functions": {
    "api/index.py": {
      "runtime": "@vercel/python@4.5.0",
      "maxDuration": 30,
      "excludeFiles": "{frontend/node_modules/**,frontend/src/**,.venv/**,aidlc-docs/**,backend/tests/**,.git/**,.idea/**,.vscode/**,.kiro/**}"
    }
  }
}
